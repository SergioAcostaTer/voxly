# ============================================================
# VoxLy Backend Configuration - EXAMPLE
# ============================================================
# Copy this file to .env and update with your actual values
# DO NOT commit the .env file to version control

# ============================================================
# DATABASE
# ============================================================
# These defaults match backend/docker-compose.yml for local development.
DATABASE_URL=jdbc:postgresql://localhost:55432/voxly
DATABASE_USERNAME=voxly_user
DATABASE_PASSWORD=voxly_password
DATABASE_DRIVER=org.postgresql.Driver

# ============================================================
# JWT & AUTHENTICATION
# ============================================================
# Generate a new JWT secret for production
JWT_SECRET_KEY=your_secure_jwt_secret_here_min_32_chars
JWT_ISSUER=VoxLy
JWT_AUDIENCE=VoxLy

# Development Auth Bypass (disabled by default for security)
# Only enable this for local development, NEVER in production
AUTH_DEV_BYPASS_ENABLED=false
AUTH_DEV_EMAIL=dev@example.com
AUTH_DEV_USERNAME=testuser
AUTH_DEV_USER_ID=11111111-1111-1111-1111-111111111111
AUTH_DEV_PASSWORD=

# ============================================================
# CLOUDFLARE R2 / S3-COMPATIBLE STORAGE
# ============================================================
# For local development, these defaults target the bundled MinIO service.
CLOUDFLARE_R2_ENDPOINT=http://localhost:19100
CLOUDFLARE_R2_REGION=us-east-1
CLOUDFLARE_R2_ACCESS_KEY_ID=voxlyminio
CLOUDFLARE_R2_ACCESS_KEY_SECRET=voxlyminiosecret
CLOUDFLARE_R2_BUCKET_NAME=voxly-sessions
CLOUDFLARE_R2_PUBLIC_URL=http://localhost:19100/voxly-sessions

# ============================================================
# OPENAI API
# ============================================================
# Get your API key from https://platform.openai.com/api-keys
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_SUPPORTED_LANGUAGES=en,es
OPENAI_DEFAULT_LANGUAGE=en
OPENAI_GPT_MODEL=gpt-3.5-turbo
OPENAI_GPT_MAX_TOKENS=1500
OPENAI_GPT_TEMPERATURE=0.7

# ============================================================
# STORAGE & FILE PROCESSING
# ============================================================
STORAGE_TEMP_DIR=/tmp/voxly-temp
MAX_FILE_SIZE_BYTES=104857600
FFMPEG_PATH=ffmpeg
FFMPEG_AUDIO_FORMAT=wav
FFMPEG_AUDIO_BITRATE=128k
FFMPEG_AUDIO_SAMPLERATE=16000

# ============================================================
# EMAIL/SMTP CONFIGURATION
# ============================================================
# Local development defaults target the bundled Mailpit service.
SMTP_HOST=localhost
SMTP_PORT=11025
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_AUTH_ENABLED=false
MAIL_STARTTLS_ENABLED=false
SMTP_FROM_EMAIL=noreply@voxly.app
ADMIN_EMAIL=admin@voxly.app

# ============================================================
# APPLICATION
# ============================================================
SERVER_PORT=8080
APP_BASE_URL=http://localhost:3000
