# ============================================================
# VoxLy Frontend Configuration - EXAMPLE
# ============================================================
# Copy this file to .env and update with your actual values
# DO NOT commit the .env file to version control

# ============================================================
# API CONFIGURATION
# ============================================================
# Backend API base URL (should not include trailing slash)
# For development: http://localhost:8080
# For production: https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:8080

# Optional: Override individual API paths (uncomment to use)
# VITE_AUTH_BASE_PATH=/v1/auth
# VITE_USERS_BASE_PATH=/v1/users

# ============================================================
# APPLICATION ENVIRONMENT
# ============================================================
# Optional: Application metadata
# VITE_APP_NAME=VoxLy
# VITE_APP_VERSION=0.0.1
