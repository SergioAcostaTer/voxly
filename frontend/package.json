{
    "name": "frontend",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:all": "concurrently --kill-others-on-fail --names backend,frontend --prefix-colors blue,green \"call ..\\backend\\gradlew.bat -p ..\\backend bootRun\" \"vite\"",
        "dev:all:testing": "concurrently --kill-others-on-fail --names backend,frontend --prefix-colors blue,green \"call ..\\backend\\gradlew.bat -p ..\\backend bootRun --args=--spring.profiles.active=testing\" \"cmd /c set VITE_AUTH_BYPASS=true&& vite\"",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "audit": "npx --yes unlighthouse --site http://localhost:5173",
        "audit:preview": "npx --yes unlighthouse --site http://localhost:4173",
        "audit:ci": "npx --yes unlighthouse-ci --site http://localhost:5173 --budget 80"
    },
    "dependencies": {
        "clsx": "^2.1.1",
        "lucide-react": "^0.577.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-router-dom": "^7.13.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.1",
        "autoprefixer": "^10.4.27",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^9.39.1",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "globals": "^16.5.0",
        "concurrently": "^9.2.1",
        "postcss": "^8.5.8",
        "tailwindcss": "^3.4.17",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.48.0",
        "vite": "^7.3.1"
    }
}
